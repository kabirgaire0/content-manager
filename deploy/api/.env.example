# Copy to deploy/api.env (gitignored by .env pattern). Fill in.

APP_ENV=prod

# REQUIRED in prod. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
STATE_SECRET=

# Public hostnames. WEB_BASE_URL is where the API redirects users back
# after Spotify OAuth. SPOTIFY_REDIRECT_URI must be added verbatim to
# the Redirect URIs list in the Spotify dashboard.
WEB_BASE_URL=https://content.example.com
SPOTIFY_REDIRECT_URI=https://api.content.example.com/spotify/callback

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# CORS — comma-separated list. The web app server-side fetches via the
# internal docker network so this only needs the public web hostname
# in case you ever expose the API to the browser directly.
CORS_ORIGINS=["https://content.example.com"]

# Whisper model. base = ~150MB, small = ~500MB, medium = ~1.5GB
# Append .en for English-only (faster, more accurate when you only
# speak English).
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8
