# Copy to deploy/web.env. Fill in.

NODE_ENV=production

# Internal URL — the web container talks to the api container over the
# internal docker network. This URL is NEVER seen by the browser.
API_BASE_URL=http://api:8000

# Public API URL — used only for the Spotify OAuth redirect. The browser
# follows a 302 to this URL on Connect, so it must be reachable from a
# phone or laptop (i.e. your public api hostname).
PUBLIC_API_BASE_URL=https://api.content.example.com
