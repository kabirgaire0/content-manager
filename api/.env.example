# Copy to api/.env and fill in. .env is gitignored.

# Where the web app runs (used for the post-OAuth redirect)
WEB_BASE_URL=http://localhost:3000

# Spotify Developer credentials.
# Create an app at https://developer.spotify.com/dashboard
# Add http://127.0.0.1:8000/spotify/callback to its Redirect URIs.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://127.0.0.1:8000/spotify/callback

# Used to sign the OAuth `state` value. Change for production.
STATE_SECRET=dev-only-state-secret-change-me
